{
  "name": "hoobi-portfolio",
  "version": "0.1.0",
  "private": true,
  "description": "Living resume and portfolio. Data-driven, served from a Fastify API with a React front end.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "dev:api": "bun --cwd packages/api run dev",
    "dev:web": "bun --cwd packages/web run dev",
    "start:api": "bun packages/api/src/server.ts",
    "lint": "bun run --filter='*' lint",
    "typecheck": "bun run --filter='*' typecheck",
    "test": "bun run --filter='*' test",
    "test:coverage": "bun run --filter='*' test:coverage",
    "test:e2e": "start-server-and-test 'bun run start:api' http-get://localhost:8090/api/health 'playwright test --project=local'",
    "test:e2e:against": "playwright test --project=remote",
    "test:api": "start-server-and-test 'bun run start:api' http-get://localhost:8090/api/health 'cd tests/api && bru run . --env local'",
    "test:api:against": "cd tests/api && bru run . --env remote",
    "sbom": "cdxgen -o packages/api/public/sbom.cdx.json -t bun --no-recurse --required-only --spec-version 1.6 .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@cyclonedx/cdxgen": "12.4.1",
    "@playwright/test": "1.60.0",
    "@usebruno/cli": "3.4.0",
    "oxlint": "1.66.0",
    "prettier": "3.8.3",
    "start-server-and-test": "3.0.5",
    "typescript": "6.0.3"
  }
}

{
  "name": "hoobi-portfolio",
  "version": "0.1.5",
  "private": true,
  "description": "Living resume and portfolio. Data-driven, served from a Fastify API with a React front end.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r --parallel run dev",
    "dev:api": "pnpm --filter @hoobi-portfolio/api run dev",
    "dev:web": "pnpm --filter @hoobi-portfolio/web run dev",
    "start:api": "node packages/api/dist/server.js",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "test:e2e": "start-server-and-test 'pnpm run start:api' http-get://localhost:8090/api/health 'playwright test --project=local'",
    "test:e2e:against": "playwright test --project=remote",
    "test:api": "start-server-and-test 'pnpm run start:api' http-get://localhost:8090/api/health 'cd tests/api && bru run . --env local'",
    "test:api:against": "cd tests/api && bru run . --env remote",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@usebruno/cli": "3.4.0",
    "oxlint": "1.66.0",
    "prettier": "3.8.3",
    "start-server-and-test": "3.0.5",
    "typescript": "6.0.3"
  }
}

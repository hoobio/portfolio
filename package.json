{
  "name": "hoobi-portfolio",
  "version": "0.1.0",
  "private": true,
  "description": "Living resume and portfolio. Data-driven, served from a Fastify API with a React front end.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "dev": "bun run --filter='*' dev",
    "dev:api": "bun --cwd packages/api run dev",
    "dev:web": "bun --cwd packages/web run dev",
    "lint": "bun run --filter='*' lint",
    "typecheck": "bun run --filter='*' typecheck",
    "test": "bun run --filter='*' test",
    "test:coverage": "bun run --filter='*' test:coverage",
    "sbom": "cdxgen -o packages/api/public/sbom.cdx.json -t bun --no-recurse --required-only .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@cyclonedx/cdxgen": "12.4.1",
    "oxlint": "1.66.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3"
  }
}

meta {
  name: openapi
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/docs/json
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(200);
  });
  test("is an openapi 3.x document", function() {
    expect(res.body.openapi).to.match(/^3\./);
  });
  test("has the portfolio path", function() {
    expect(res.body.paths["/api/portfolio"]).to.exist;
  });
}

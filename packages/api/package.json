{
  "name": "@hoobi-portfolio/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --target=node24 --format=esm --external:fastify --external:@fastify/* --external:fastify-type-provider-zod --external:yaml --external:zod --external:pino-pretty --outfile=dist/server.js --sourcemap",
    "start": "node dist/server.js",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/static": "9.1.3",
    "@fastify/swagger": "9.7.0",
    "@fastify/swagger-ui": "5.2.6",
    "@hoobi-portfolio/schemas": "workspace:*",
    "fastify": "5.9.0",
    "fastify-type-provider-zod": "6.1.0",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "25.9.4",
    "@vitest/coverage-v8": "4.1.9",
    "esbuild": "0.28.1",
    "oxlint": "1.72.0",
    "pino-pretty": "13.1.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
